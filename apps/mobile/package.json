{
  "name": "@ai-chat-box/mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node -e \"const m=require('module');const b=m.builtinModules;Object.defineProperty(m,'builtinModules',{get:()=>b.filter(x=>!x.includes(':'))});process.argv.splice(1,1);require('../../node_modules/expo/bin/cli')\" start",
    "android": "node -e \"const m=require('module');const b=m.builtinModules;Object.defineProperty(m,'builtinModules',{get:()=>b.filter(x=>!x.includes(':'))});process.argv.splice(1,1);require('../../node_modules/expo/bin/cli')\" start --android",
    "ios": "node -e \"const m=require('module');const b=m.builtinModules;Object.defineProperty(m,'builtinModules',{get:()=>b.filter(x=>!x.includes(':'))});process.argv.splice(1,1);require('../../node_modules/expo/bin/cli')\" start --ios",
    "web": "node -e \"const m=require('module');const b=m.builtinModules;Object.defineProperty(m,'builtinModules',{get:()=>b.filter(x=>!x.includes(':'))});process.argv.splice(1,1);require('../../node_modules/expo/bin/cli')\" start --web"
  },
  "dependencies": {
    "@ai-chat-box/shared": "*",
    "@react-native-async-storage/async-storage": "1.21.0",
    "axios": "^1.15.2",
    "expo": "~50.0.4",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-native": "0.73.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "typescript": "^5.3.3"
  },
  "private": true
}
