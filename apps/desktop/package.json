{
  "name": "@ai-chat-box/desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.aichatbox.app",
    "productName": "AI-Chat-Box",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  }
}
